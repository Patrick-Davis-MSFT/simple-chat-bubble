{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start UI - Backend (App Hosting)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "./scripts/run_ui_local.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Weather MCP (Local)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "./scripts/run_weather_webapp_local.sh .azure/bubble-chat/.env"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ]
}
